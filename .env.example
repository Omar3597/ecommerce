# Database Config (Local Docker)
DB_HOST=postgres
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=secret_dev_password
DB_NAME=ecommerce_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=secret_dev_password
POSTGRES_DB=ecommerce_db
DATABASE_URL=postgres://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${DB_HOST}:${DB_PORT}/${POSTGRES_DB}

# App Config
NODE_ENV=development
APP_PORT=3000
BASE_URL=http://localhost:3000/api/v1

# Security & Auth
JWT_SECRET=jwt_dev_secret_key_123
REFRESH_TOKEN_SECRET=refresh_dev_secret_key_456

# Mailer (e.g., Mailtrap / Sandbox)
MAIL_HOST=sandbox.smtp.io
MAIL_PORT=2525
MAIL_USER=dev_user
MAIL_PASSWORD=dev_secret

# Stripe (Test Mode Keys)
STRIPE_SECRET_KEY=sk_test_your_stripe_test_key
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret
STRIPE_SUCCESS_URL=http://localhost:${APP_PORT}/checkout/success
STRIPE_CANCEL_URL=http://localhost:${APP_PORT}/checkout/cancel

# External storage (e.g., Cloudinary)
CLOUDINARY_CLOUD_NAME=your_cloud_name_here
CLOUDINARY_API_KEY=123456789012345
CLOUDINARY_API_SECRET=your_api_secret_key_here

# Business Logic Limits
MAX_CART_QUANTITY=10
MAX_ACTIVE_SESSIONS=5