generator client {
  provider      = "prisma-client"
  output        = "../generated/prisma"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  MANAGER
  ADMIN
  USER
}

enum OrderStatus {
  PENDING
  PAID
  SHIPPED
  DELIVERED
  CANCELLED
}

enum TokenType {
  VERIFICATION
  PASSWORD_RESET
  REACTIVATION
  EMAIL_CHANGE
}

model User {
  id                String    @id @default(uuid())
  name              String    @db.VarChar(100)
  email             String    @unique @db.VarChar(255)
  pendingEmail      String?   @unique @db.VarChar(255)
  role              Role      @default(USER)
  isVerified        Boolean   @default(false)
  isDeleted         Boolean   @default(false)
  isBanned          Boolean   @default(false)
  password          String    @db.VarChar(255)
  passwordChangedAt DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  //relations 

  cart         Cart?
  addresses    Address[]
  orders       Order[]
  refreshToken RefreshToken[]
  shortTokens  ShortToken[]
  reviews      Review[]

  @@map("users")
}

model Product {
  id          String  @id @default(uuid())
  name        String  @db.VarChar(100)
  description String? @db.VarChar(1500)
  summary     String  @db.VarChar(200)
  price       Int
  stock       Int     @default(1)
  isHidden    Boolean @default(false)
  ratingAvg   Decimal @default(0) @db.Decimal(10, 2)
  ratingCount Int     @default(0)

  soldQuantity Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  //relations
  category   Category    @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  cartItems  CartItem[]
  reviews    Review[]
  categoryId String
  orderItems OrderItem[]

  @@map("products")
}

model Category {
  id        String   @id @default(uuid())
  name      String   @db.VarChar(100)
  slug      String   @unique @db.VarChar(120)
  isHidden  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  products Product[]
}

model Cart {
  id     String @id @default(uuid())
  userId String @unique

  //relations

  user  User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  items CartItem[]

  @@index([userId])
  @@map("carts")
}

model CartItem {
  id        String @id @default(uuid())
  quantity  Int
  cartId    String
  productId String

  //relations
  cart    Cart    @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([cartId, productId])
  @@map("cart_items")
}

model Order {
  id            String      @id @default(uuid())
  subtotal      Int
  shippingFee   Int
  total         Int
  status        OrderStatus @default(PENDING)
  expiresAt     DateTime
  transactionId String?     @unique
  userId        String
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  //relations
  user            User                  @relation(fields: [userId], references: [id])
  items           OrderItem[]
  addressSnapshot OrderAddressSnapshot?

  @@index([userId])
  @@map("orders")
}

model OrderItem {
  id                String  @id @default(uuid())
  quantity          Int
  // snapshot fields used by order service
  orderId           String
  productId         String?
  productSnapshotId String  @unique

  //relations
  order           Order                  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product         Product?               @relation(fields: [productId], references: [id], onDelete: SetNull)
  productSnapshot OrderedProductSnapshot @relation(fields: [productSnapshotId], references: [id])

  @@index([orderId])
  @@index([productSnapshotId])
  @@map("order_items")
}

model Address {
  id        String   @id @default(uuid())
  fullName  String   @db.VarChar(100)
  phone     String   @db.VarChar(30)
  city      String   @db.VarChar(100)
  street    String   @db.VarChar(200)
  building  String?  @db.VarChar(100)
  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  //relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("addresses")
}

model OrderAddressSnapshot {
  id        String   @id @default(uuid())
  fullName  String   @db.VarChar(100)
  phone     String   @db.VarChar(30)
  city      String   @db.VarChar(100)
  street    String   @db.VarChar(200)
  building  String?  @db.VarChar(100)
  orderId   String   @unique
  createdAt DateTime @default(now())

  //relations
  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("order_address_snapshots")
}

model OrderedProductSnapshot {
  id         String     @id @default(uuid())
  name       String     @db.VarChar(100)
  summary    String     @db.VarChar(200)
  price      Int
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  orderItems OrderItem?

  @@map("ordered_product_snapshot")
}

model ShortToken {
  id        String    @id @default(uuid())
  token     String    @unique
  type      TokenType
  expiresAt DateTime
  createdAt DateTime  @default(now())
  userId    String

  ///relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, type])
  @@index([userId])
  @@index([expiresAt])
  @@map("short_tokens")
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  //relations 
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
  @@map("refresh_token")
}

model Review {
  id      String  @id @default(uuid())
  rating  Int
  comment String? @db.VarChar(1000)

  userId    String
  productId String

  user    User    @relation(fields: [userId], references: [id])
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, productId])
  @@index([productId])
}
