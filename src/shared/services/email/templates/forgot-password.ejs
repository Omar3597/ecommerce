<!DOCTYPE html>
<html>
<head>
    <style>
        body { font-family: sans-serif; line-height: 1.6; }
        .container { max-width: 600px; margin: 0 auto; padding: 20px; }
        .btn { display: inline-block; padding: 10px 20px; background-color: #dc3545; color: white; text-decoration: none; border-radius: 5px; }
    </style>
</head>
<body>
    <div class="container">
        <h2>Hello <%= name %>,</h2>
        <p>You recently requested to reset your password. Click the link below to set a new password:</p>
        <p>
            <a href="<%= resetUrl %>" class="btn">Reset Password</a>
        </p>
        <p>This link will expire in <%= expiresInMinutes %> minutes.</p>
        <p>If you didn't request a password reset, you can safely ignore this email.</p>
    </div>
</body>
</html>
