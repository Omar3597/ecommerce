{
  "compilerOptions": {
    "module": "CommonJS",
    "moduleResolution": "node",
    "target": "ES2023",
    "strict": true,
    "esModuleInterop": true,
    "outDir": "./dist",
    "rootDir": "."
  },
  "include": ["src/**/*.ts", "generated/prisma/**/*.ts", "prisma/seed/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
